{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    "security:openssf-scorecard",
    ":disableDependencyDashboard"
  ],
  "pre-commit": { "enabled": true },
  "reviewers": ["ardubev16", "LuigiMiazzo17"],
  "argocd": {
    "managerFilePatterns": [
      "/^appsets/.+\\.yaml$/",
      "/^root-argocd-app\\.yaml$/"
    ]
  },
  "kubernetes": { "managerFilePatterns": ["/^.+\\.yaml$/"] },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^.+/kustomization\\.yaml$/"],
      "matchStrings": [
        "https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/(?<currentValue>[^/]+)/.*"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^.+/kustomization\\.yaml$/"],
      "matchStrings": [
        "https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/(?<currentValue>[^/]+)/.*"
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\s+\\w+: \"(?<currentValue>[^\"]+)\""
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Batch all CI updates into one PR, automerged once a week in the Monday 3am window",
      "groupName": "Actions & Checks",
      "matchFileNames": [".github/workflows/**", ".pre-commit-config.yaml"],
      "separateMajorMinor": false,
      "separateMinorPatch": false,
      "automerge": true,
      "automergeSchedule": ["* 3 * * 1"],
      "platformAutomerge": false,
      "automergeStrategy": "squash"
    },
    {
      "matchFileNames": ["infrastructure/**"],
      "groupName": "infrastructure non-major",
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "matchFileNames": ["platform/**"],
      "groupName": "platform non-major",
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "matchFileNames": ["applications/icinga/**"],
      "groupName": "icinga2",
      "reviewers": ["LuigiMiazzo17"],
      "separateMajorMinor": false,
      "separateMinorPatch": false
    },
    {
      "matchPackageNames": ["kubernetes-sigs/*"],
      "groupName": "kubernetes-sigs",
      "separateMajorMinor": false,
      "separateMinorPatch": false
    },
    {
      "matchPackageNames": ["ghcr.io/guss-alberto/unitntgbot-*"],
      "groupName": "unitntgbot",
      "separateMajorMinor": false,
      "separateMinorPatch": false,
      "reviewers": ["ardubev16"],
      "automerge": true
    },
    {
      "matchPackageNames": ["ghcr.io/pelican-dev/*"],
      "versioning": "loose",
      "ignoreUnstable": false
    }
  ]
}
